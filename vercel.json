{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "builds": [
    {
      "src": "mkdocs.yml",
      "use": "@vercel/static-build",
      "config": {
        "pythonVersion": "3.12"
      }
    }
  ],
  "buildCommand": "uv sync && uv run mkdocs build -d public --clean",
  "outputDirectory": "public"
}
